APP_NAME=Altur Backend
APP_ENV=local
DEBUG=false

# Local Supabase Postgres plus local filesystem audio storage.
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
SUPABASE_STORAGE_BUCKET=call-audio
STORAGE_BACKEND=local
LOCAL_STORAGE_ROOT=.data/storage
MAX_CALL_UPLOAD_BYTES=524288000

# Optional production-style Supabase Storage.
# STORAGE_BACKEND=supabase
# SUPABASE_URL=https://example.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=replace-me

# Speech to text.
ELEVENLABS_API_KEY=
ELEVENLABS_STT_MODEL_ID=scribe_v1

# LLM analysis.
OPENAI_API_KEY=
OPENAI_ANALYSIS_MODEL=gpt-4.1-mini
ANALYSIS_PROMPT_VERSION=altur-analysis-v1
